DOCKER_USER := "spilikin"

# Every module — library AND command — is versioned solely by its own git tag
# (go/<module>/vX.Y.Z), bumped only when that module changes. The local/Docker build stamp
# is derived from `git describe` (see `_modver`); `go install` reads the version from the
# module build info. Bump by tagging: `just tag <module> <version>` (see `versions`/`changed`).

# Upstream Caddy version, derived from zaddy/go.mod (single source of truth). Used as
# SemVer build metadata for the zero-caddy image tag, e.g. zero-caddy:0.20.2-caddy2.11.4.
CADDY_VERSION := `grep -E 'caddyserver/caddy/v2 v[0-9]' zaddy/go.mod | head -1 | awk '{print $2}' | sed 's/^v//'`

# Display available commands
info:
    just --list

# (internal) A module's version from its latest go/<mod>/v* tag via git describe, else "dev".
_modver mod:
    #!/usr/bin/env bash
    v=$(git describe --tags --match "go/{{mod}}/v*" 2>/dev/null | sed 's|.*/v||')
    echo "${v:-dev}"

# Build all command binaries locally into ./dist (version from git tag via ldflags)
build: build-epa build-pdp build-caddy build-ti

# Build the zero-epa binary locally
build-epa:
    go build -ldflags "-X github.com/gematik/zero-lab/go/epa.Version=$(just _modver epa)" -o dist/zero-epa ./epa/cmd/zero-epa

# Build the zero-pdp binary locally
build-pdp:
    go build -ldflags "-X github.com/gematik/zero-lab/go/pdp.Version=$(just _modver pdp)" -o dist/zero-pdp ./pdp/cmd/zero-pdp

# Build the zero-caddy binary locally
build-caddy:
    go build -ldflags "-X main.Version=$(just _modver zaddy)" -o dist/zero-caddy ./zaddy/cmd/zero-caddy

# Build the ti CLI binary locally
build-ti:
    go build -ldflags "-X main.Version=$(just _modver ti)" -o dist/ti ./ti


# Build the zero-epa docker image
docker-build-epa:
    #!/usr/bin/env bash
    set -euo pipefail
    v=$(just _modver epa)
    docker build --platform linux/amd64 --build-arg VERSION="$v" -t "{{DOCKER_USER}}/zero-epa:$v" -f ./epa/cmd/zero-epa/Dockerfile .
    docker tag "{{DOCKER_USER}}/zero-epa:$v" "{{DOCKER_USER}}/zero-epa:latest"

# Push the zero-epa docker image to the docker hub
docker-push-epa: docker-build-epa
    #!/usr/bin/env bash
    set -euo pipefail
    v=$(just _modver epa)
    docker push "{{DOCKER_USER}}/zero-epa:$v"
    docker push "{{DOCKER_USER}}/zero-epa:latest"

# Build the zero-caddy docker image (tag combines our version + Caddy version)
docker-build-caddy:
    #!/usr/bin/env bash
    set -euo pipefail
    v=$(just _modver zaddy)
    docker build --platform linux/amd64 --build-arg VERSION="$v" -t "{{DOCKER_USER}}/zero-caddy:$v-caddy{{CADDY_VERSION}}" -f ./zaddy/cmd/zero-caddy/Dockerfile .
    docker tag "{{DOCKER_USER}}/zero-caddy:$v-caddy{{CADDY_VERSION}}" "{{DOCKER_USER}}/zero-caddy:latest"

# Push the zero-caddy docker image to the docker hub
docker-push-caddy: docker-build-caddy
    #!/usr/bin/env bash
    set -euo pipefail
    v=$(just _modver zaddy)
    docker push "{{DOCKER_USER}}/zero-caddy:$v-caddy{{CADDY_VERSION}}"
    docker push "{{DOCKER_USER}}/zero-caddy:latest"

# Build the zero-pdp docker image
docker-build-pdp:
    #!/usr/bin/env bash
    set -euo pipefail
    v=$(just _modver pdp)
    docker build --platform linux/amd64 --build-arg VERSION="$v" -t "{{DOCKER_USER}}/zero-pdp:$v" -f ./pdp/cmd/zero-pdp/Dockerfile .
    docker tag "{{DOCKER_USER}}/zero-pdp:$v" "{{DOCKER_USER}}/zero-pdp:latest"

# Push the zero-pdp docker image to the docker hub
docker-push-pdp: docker-build-pdp
    #!/usr/bin/env bash
    set -euo pipefail
    v=$(just _modver pdp)
    docker push "{{DOCKER_USER}}/zero-pdp:$v"
    docker push "{{DOCKER_USER}}/zero-pdp:latest"

# Tag a module at a version, e.g. `just tag ti 0.20.2` or `just tag brainpool 0.3.1`
# -> go/<module>/vX.Y.Z. Tag only the modules that changed (see `changed`).
tag name version:
    git tag -a "go/{{name}}/v{{version}}" -m "{{name}} v{{version}}"

# Show the latest release tag for every module.
versions:
    #!/usr/bin/env bash
    set -euo pipefail
    for dir in $(find . -name go.mod -not -path './libzero/*' -exec dirname {} \; | sed 's|^\./||' | sort); do
        latest=$(git tag -l "go/$dir/v*" | sort -V | tail -1)
        printf '%-12s %s\n' "$dir" "${latest:-<untagged>}"
    done

# List modules with commits since their latest tag (candidates for a version bump).
changed:
    #!/usr/bin/env bash
    set -euo pipefail
    for dir in $(find . -name go.mod -not -path './libzero/*' -exec dirname {} \; | sed 's|^\./||' | sort); do
        latest=$(git tag -l "go/$dir/v*" | sort -V | tail -1)
        if [ -z "$latest" ]; then
            echo "$dir: never tagged"
        elif [ -n "$(git log --oneline "$latest"..HEAD -- "$dir")" ]; then
            echo "$dir: changed since $latest"
        fi
    done

# Push all local tags to origin
push-tags:
    git push origin --tags

# Repin every in-repo (zero-lab/go) require to the latest commit on a git ref
# (default: current branch) so that tagged command builds — `go install ...@<tag>`,
# which ignore go.work — pick up the latest library code. PUSH library changes first:
# this fetches the modules from the remote at REF and records their pseudo-versions.
sync REF=`git rev-parse --abbrev-ref HEAD`:
    #!/usr/bin/env bash
    set -euo pipefail
    # Resolve in-repo modules straight from the VCS: proxy.golang.org cannot resolve a
    # branch ref (and negatively caches unreleased versions), so a proxy fetch no-ops.
    export GOPRIVATE=github.com/gematik/zero-lab
    for dir in $(find . -name 'go.mod' -not -path './libzero/*' -exec dirname {} \;); do
        ( cd "$dir"
          self=$(awk 'NR==1{print $2}' go.mod)
          for dep in $(grep -oE 'github\.com/gematik/zero-lab/go/[a-zA-Z0-9]+' go.mod | sort -u); do
              [ "$dep" = "$self" ] && continue
              echo "==> $self: get $dep@{{REF}}"
              go get "$dep@{{REF}}"
          done )
    done
    go work sync

# Tidy all go modules: sync go.mod/go.sum to imports. Does NOT upgrade versions.
tidy:
    #!/usr/bin/env bash
    set -euo pipefail
    for dir in $(find . -name 'go.mod' -not -path './libzero/*' -exec dirname {} \; | sort); do
        echo "==> Tidying $dir"
        (cd "$dir" && go mod tidy)
    done

# Upgrade all external dependencies to their latest versions, then tidy. Deliberate
# action — re-floats deps, so re-run `just sync` before tagging a release.
upgrade:
    #!/usr/bin/env bash
    set -euo pipefail
    for dir in $(find . -name 'go.mod' -not -path './libzero/*' -exec dirname {} \; | sort); do
        echo "==> Upgrading $dir"
        (cd "$dir" && go get -u ./... && go mod tidy)
    done

# Update roots.json files for embedded use
update-roots:
    curl -o ./gempki/roots-test.json https://download-test.tsl.ti-dienste.de/ECC/ROOT-CA/roots.json
    curl -o ./gempki/roots-dev-ref.json https://download-ref.tsl.ti-dienste.de/ECC/ROOT-CA/roots.json
    curl -o ./gempki/roots-prod.json https://download.tsl.ti-dienste.de/ECC/ROOT-CA/roots.json

# --- zero-pdp e2e (see docs/e2e.md) ---

# Start zero-pdp for e2e against URL (the issuer). Generates sign.jwk and a client-secret hash
# from ZERO_PDP_E2E_CLIENT_SECRET (default "e2e-secret"), then serves the e2e testdata config.
pdp-e2e-serve URL='http://localhost:8011':
    #!/usr/bin/env bash
    set -euo pipefail
    td=pdp/e2e/testdata
    [ -f "$td/sign.jwk" ] || go run ./pdp/cmd/zero-pdp jose generate-jwk > "$td/sign.jwk"
    export ZERO_PDP_E2E_URL='{{URL}}'
    export ZERO_PDP_E2E_CLIENT_ID="${ZERO_PDP_E2E_CLIENT_ID:-e2e-client}"
    export ZERO_PDP_E2E_REDIRECT_URI="${ZERO_PDP_E2E_REDIRECT_URI:-http://localhost:8765/as-callback}"
    export ZERO_PDP_E2E_CLIENT_SECRET_HASH="$(go run ./pdp/cmd/zero-pdp secret-hash "${ZERO_PDP_E2E_CLIENT_SECRET:-e2e-client}")"
    echo "serving zero-pdp: issuer={{URL}} client=$ZERO_PDP_E2E_CLIENT_ID"
    go run ./pdp/cmd/zero-pdp start -f pdp.e2e.yaml -w "$td"

# Run smoke+regression+flow e2e suites against a running server at URL.
pdp-e2e URL='http://localhost:8011':
    ZERO_PDP_E2E_URL='{{URL}}' ZERO_PDP_E2E_CLIENT_SECRET="${ZERO_PDP_E2E_CLIENT_SECRET:-e2e-client}" go test ./pdp/e2e -run 'Smoke|Regression|Flow' -count=1 -v

# Run only the smoke suite.
pdp-e2e-smoke URL='http://localhost:8011':
    ZERO_PDP_E2E_URL='{{URL}}' go test ./pdp/e2e -run Smoke -count=1 -v

# Run the human-in-the-loop authorization-code flow (opens a browser; needs an OP configured).
# Provide the public URL explicitly, e.g. `just pdp-e2e-hitl https://<rathole-host>`.
pdp-e2e-hitl URL:
    ZERO_PDP_E2E_URL='{{URL}}' ZERO_PDP_E2E_HITL=1 ZERO_PDP_E2E_CLIENT_SECRET="${ZERO_PDP_E2E_CLIENT_SECRET:-e2e-client}" go test ./pdp/e2e -run HITL -count=1 -v -timeout 5m
