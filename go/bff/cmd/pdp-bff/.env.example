# Public origin the demo is reached at — e.g. your rathole tunnel URL. Used as the issuer and the redirect
# base, and referenced by ${PUBLIC_URL} inside config/pdp.yaml.
PUBLIC_URL=https://your-tunnel.example.com

# The bff's client_id. pdp-bff generates the bff's signing + DPoP keys at startup and registers it (with its
# public JWK) automatically as a private_key_jwt (RFC 7523) client — there is no secret to configure.
BFF_CLIENT_ID=bff-demo

# Google OIDC provider (https://console.cloud.google.com -> OAuth client). Authorized redirect URI:
#   ${PUBLIC_URL}/as/op-callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
