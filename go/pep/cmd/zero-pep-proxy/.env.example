# OIDC provider for the S1 HITL. Register this redirect_uri at the provider before running:
#   http://127.0.0.1:8480/oauth2/callback
#
# The public origin the browser reaches the proxy at (the Caddy front).
PEP_PUBLIC_URL=http://127.0.0.1:8480

# A standard OIDC provider (discovery at <issuer>/.well-known/openid-configuration). Google shown as an
# example; any confidential OIDC client works.
PEP_OIDC_ISSUER=https://accounts.google.com
PEP_OIDC_CLIENT_ID=
PEP_OIDC_CLIENT_SECRET=
PEP_OIDC_SCOPES=openid email profile
PEP_OIDC_NAME=Google

# id_token clock-skew tolerance (Go duration). Default 1m. Raise it if your Docker VM clock drifts.
PEP_OIDC_ACCEPTABLE_SKEW=1m
