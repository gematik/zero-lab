# Single-OIDC env for the docker-compose HITL (`cp .env.example .env`, then `docker compose up --build`).
# Register this redirect_uri at the provider before running:
#   http://127.0.0.1:8080/oauth2/callback
#
# For several providers, use openid-providers.yaml
# (PEP_OPENID_PROVIDERS_PATH, default ./openid-providers.yaml) — see openid-providers.example.yaml.

# The public origin the browser reaches the proxy at (the Caddy front).
PEP_PUBLIC_URL=http://127.0.0.1:8080

# The session cookie is __Host-/Secure by default; http://127.0.0.1 can't carry that, so relax it for this
# local demo. Leave it unset behind HTTPS.
PEP_INSECURE_COOKIE=true

# A standard OIDC provider (discovery at <issuer>/.well-known/openid-configuration). Google shown as an
# example; any confidential OIDC client works.
PEP_OIDC_ISSUER=https://accounts.google.com
PEP_OIDC_CLIENT_ID=
PEP_OIDC_CLIENT_SECRET=
PEP_OIDC_SCOPES=openid email profile
PEP_OIDC_NAME=Google

# id_token clock-skew tolerance (Go duration). Default 1m. Raise it if your Docker VM clock drifts.
PEP_OIDC_ACCEPTABLE_SKEW=1m
